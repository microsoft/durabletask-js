{
    "version": "2.0",
    "logging": {
        "applicationInsights": {
            "samplingSettings": {
                "isEnabled": true,
                "excludedTypes": "Request"
            }
        }
    },
    "extensionBundle": {
        "id": "Microsoft.Azure.Functions.ExtensionBundle.Preview",
        "version": "[4.29.0, 5.0.0)"
    },
    "extensions": {
        "durableTask": {
            "storageProvider": {
                "type": "AzureStorage"
            },
            "maxGrpcMessageSizeInBytes": 2147483647
        }
    }
}
